---
const { eyebrow, h1Lead, h1Em, h1Trail, lead, ctaLabel = 'Book a site visit', ctaHref = '/contact' } = Astro.props;
---
<section class="page-hero">
  <div class="page-hero-inner">
    <div class="eyebrow">{eyebrow}</div>
    <h1>{h1Lead}{h1Em && <span><br/><em>{h1Em}</em></span>}{h1Trail}</h1>
    <p class="lead">{lead}</p>
    <div class="actions">
      <a class="btn btn-primary-dark" href={ctaHref}>{ctaLabel} →</a>
    </div>
  </div>
</section>

<section class="placeholder">
  <div class="placeholder-inner">
    <p class="placeholder-msg">This page is under construction.</p>
    <p class="placeholder-sub">The full content is being built. In the meantime, please book a site visit and we'll walk you through it in person.</p>
    <a class="btn btn-primary-light" href="/contact">Book a site visit →</a>
  </div>
</section>

<style>
  .page-hero { background: var(--dark); color: var(--text-dark); padding: 90px var(--pad) 70px; position: relative; overflow: hidden; }
  .page-hero::before { content: ''; position: absolute; right: -15%; top: -10%; width: 65%; height: 90%; background: radial-gradient(circle at 50% 50%, rgba(0,213,255,0.10), transparent 55%); pointer-events: none; }
  .page-hero-inner { max-width: var(--maxw); margin: 0 auto; position: relative; }
  .eyebrow { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--cyan); margin-bottom: 24px; display: flex; align-items: center; gap: 12px; }
  .eyebrow::before { content: ''; width: 32px; height: 1px; background: var(--cyan); }
  .page-hero h1 { font-size: 72px; letter-spacing: -0.035em; margin-bottom: 26px; line-height: 0.96; max-width: 720px; }
  .page-hero h1 em { color: var(--cyan); }
  .lead { font-size: 18px; line-height: 1.6; color: var(--text-dark-mid); font-weight: 300; max-width: 600px; margin-bottom: 34px; }
  .actions { display: flex; gap: 12px; }
  .placeholder { background: var(--light); padding: 120px var(--pad); text-align: center; }
  .placeholder-inner { max-width: 540px; margin: 0 auto; }
  .placeholder-msg { font-family: var(--f-display); font-size: 32px; letter-spacing: -0.02em; margin-bottom: 16px; }
  .placeholder-sub { font-size: 16px; line-height: 1.6; color: var(--mid); margin-bottom: 32px; }
  @media (max-width: 920px) { .page-hero h1 { font-size: 44px; } }
</style>
