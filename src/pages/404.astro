---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found">
<section style="background: var(--dark); color: var(--text-dark); min-height: 70vh; display: flex; align-items: center; justify-content: center; padding: 80px 36px; text-align: center;">
  <div>
    <div style="font-family: var(--f-mono); font-size: 12px; letter-spacing: 0.2em; color: var(--cyan); margin-bottom: 20px; text-transform: uppercase;">Error 404</div>
    <h1 style="font-family: var(--f-display); font-size: 64px; line-height: 1; letter-spacing: -0.03em; margin-bottom: 18px;">Wrong turn.</h1>
    <p style="font-size: 17px; color: var(--text-dark-mid); line-height: 1.6; max-width: 440px; margin: 0 auto 32px; font-weight: 300;">That page doesn't exist, or doesn't exist yet. Head back home.</p>
    <a href="/" class="btn btn-primary-dark">← Back to homepage</a>
  </div>
</section>
</Base>
